{
  "name": "auto-translator-native-desktop",
  "version": "1.0.0",
  "description": "Cross-platform desktop build for Auto Translator Native.",
  "main": "src/main.js",
  "author": "ggglitter",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node scripts/check-config.mjs",
    "dist": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:win": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "electron-updater": "6.6.2",
    "mammoth": "1.10.0",
    "pdf-parse": "1.1.1"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.codex.autotranslator.native",
    "productName": "Auto Translator Native",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ggglitter",
        "repo": "auto-translator-native"
      }
    ]
  }
}
